# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
# (.env.local 은 git 에 올라가지 않습니다)

# --- Supabase (RSVP·배달 신청 저장) ---
# https://supabase.com → 프로젝트 생성 → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 키 — 서버(어드민)에서만 사용. 절대 공개 금지.
SUPABASE_SERVICE_ROLE_KEY=

# --- 카카오맵 임베드 ---
# https://developers.kakao.com → 앱 키 → JavaScript 키 (Web 도메인 등록 필요)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# --- /admin 관리자 비밀번호 ---
ADMIN_PASSWORD=

# --- 솔라피 SMS (확정 시 문자 발송) ---
# https://solapi.com → API Key. 발신번호는 사전 등록 필요.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
