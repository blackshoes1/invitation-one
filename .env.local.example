# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
# (.env.local 은 git 에 올라가지 않습니다)

# --- Supabase (RSVP 저장) ---
# https://supabase.com → 프로젝트 생성 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 카카오맵 임베드 ---
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 플랫폼 > Web 에 사이트 도메인(localhost:3000, vercel 주소) 등록 필요
NEXT_PUBLIC_KAKAO_MAP_KEY=
